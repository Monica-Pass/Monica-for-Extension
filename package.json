{
  "name": "monica-browser-extension",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Monica-Pass/Monica-for-Extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "test:webdav": "vitest run src/providers/webdav",
    "test:bitwarden": "vitest run src/providers/bitwarden",
    "test:e2e": "npm run build && playwright test",
    "build": "npm run check && vite build && node scripts/build-workers.mjs",
    "validate": "npm test && npm run build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@m3e/web": "^2.5.8",
    "@vitejs/plugin-vue": "^6.0.7",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "lit": "^3.3.3",
    "material-symbols": "^0.45.8",
    "tslib": "^2.8.1",
    "vite": "^8.0.16",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}

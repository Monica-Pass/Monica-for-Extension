{
  "name": "monica-browser-extension",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.14.0",
    "npm": "10.9.2"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Monica-Pass/Monica-for-Extension.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "check": "tsc -b --pretty false",
    "test": "vitest run",
    "test:webdav": "vitest run src/providers/webdav",
    "test:bitwarden": "vitest run src/providers/bitwarden",
    "test:security": "vitest run src/security src/runtime/sender-policy.test.ts src/passkey/request-policy.test.ts src/passkey/webauthn-core.test.ts src/content/wallet-dom.test.ts && npm run build && node scripts/security-audit.mjs",
    "test:e2e": "npm run build && playwright test",
    "capture:store-assets": "npm run build && node scripts/capture-store-assets.mjs",
    "build": "npm run check && vite build && node scripts/build-workers.mjs",
    "validate": "npm test && npm run build",
    "package:release": "npm run build && node scripts/package-release.mjs",
    "package:verify": "node scripts/verify-release.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org",
    "verify:toolchain": "node scripts/verify-toolchain.mjs",
    "verify:workflows": "node scripts/verify-workflows.mjs",
    "verify:supply-chain": "npm run verify:toolchain && npm run verify:workflows",
    "release:check": "npm run verify:supply-chain && npm run audit:production && npm run validate && npm run test:security && npm run test:e2e && npm run package:release && npm run package:verify",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@m3e/web": "^2.5.8",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "lit": "^3.3.3",
    "material-symbols": "^0.45.8",
    "tslib": "^2.8.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10"
  }
}
